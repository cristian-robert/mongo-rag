# --- API ---
# Browser-visible. Used by client-side fetches and the FastAPI backend URL.
NEXT_PUBLIC_API_URL=http://localhost:8100

# --- App URL (origin) ---
# Used for Stripe redirect URLs, robots.txt, sitemap.xml.
NEXT_PUBLIC_APP_URL=http://localhost:3100

# --- Supabase Auth ---
# Public — safe to expose to the browser. Replace with your project values.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Server-only — bypasses RLS. NEVER expose to the browser. Used by service
# role tasks (none in apps/web today; reserved for future server-side admin
# operations such as deleting tenants).
SUPABASE_SECRET_KEY=sb_secret_replace_me

# --- Stripe (publishable key only — never publish secret keys) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
